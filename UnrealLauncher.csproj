<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>UnrealLauncher</AssemblyName>
    <RootNamespace>UnrealLauncher</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3537.50" />
  </ItemGroup>

  <ItemGroup>
    <Reference Remove="Microsoft.Web.WebView2.Wpf" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="index.html;styles.css;app.js;README.md" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="assets\**\*.*" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="locales\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
